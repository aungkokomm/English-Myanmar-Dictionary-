<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AkkDictionary.MAUI.Views.AboutPage"
             Title="About"
             BackgroundColor="{StaticResource PageBackgroundColor}">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20">
            
            <!-- App Title -->
            <Label Text="AKK En-to-MM Dictionary"
                   FontSize="28"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center"
                   TextColor="{StaticResource PrimaryColor}" />

            <!-- Description -->
            <Label Text="A comprehensive English to Myanmar dictionary"
                   FontSize="16"
                   HorizontalTextAlignment="Center"
                   TextColor="{StaticResource TextColor}" />

            <BoxView HeightRequest="1" Color="#E0E0E0" />

            <!-- Version -->
            <Label Text="Version 1.0.0"
                   FontSize="14"
                   HorizontalTextAlignment="Center"
                   TextColor="{StaticResource LightTextColor}" />

            <!-- Technology Stack -->
            <VerticalStackLayout Spacing="5">
                <Label Text="Built With:"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="{StaticResource TextColor}" />
                <Label Text="• .NET 8.0"
                       FontSize="13"
                       TextColor="{StaticResource LightTextColor}"
                       Margin="10,0,0,0" />
                <Label Text="• MAUI (Multi-platform App UI)"
                       FontSize="13"
                       TextColor="{StaticResource LightTextColor}"
                       Margin="10,0,0,0" />
                <Label Text="• SQLite Database"
                       FontSize="13"
                       TextColor="{StaticResource LightTextColor}"
                       Margin="10,0,0,0" />
                <Label Text="• 10,000+ English-Myanmar entries"
                       FontSize="13"
                       TextColor="{StaticResource LightTextColor}"
                       Margin="10,0,0,0" />
            </VerticalStackLayout>

            <BoxView HeightRequest="1" Color="#E0E0E0" />

            <!-- Features -->
            <VerticalStackLayout Spacing="5">
                <Label Text="Features:"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="{StaticResource TextColor}" />
                <Label Text="• English to Myanmar Search"
                       FontSize="13"
                       TextColor="{StaticResource LightTextColor}"
                       Margin="10,0,0,0" />
                <Label Text="• Myanmar to English Reverse Search"
                       FontSize="13"
                       TextColor="{StaticResource LightTextColor}"
                       Margin="10,0,0,0" />
                <Label Text="• Search Suggestions"
                       FontSize="13"
                       TextColor="{StaticResource LightTextColor}"
                       Margin="10,0,0,0" />
                <Label Text="• Multi-platform Support (Windows, Mac, Android)"
                       FontSize="13"
                       TextColor="{StaticResource LightTextColor}"
                       Margin="10,0,0,0" />
            </VerticalStackLayout>

            <BoxView HeightRequest="1" Color="#E0E0E0" />

            <!-- GitHub Section -->
            <VerticalStackLayout Spacing="10" Padding="15" BackgroundColor="#F7FAFC" CornerRadius="8">
                <Label Text="Open Source Project"
                       FontSize="14"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center"
                       TextColor="{StaticResource PrimaryColor}" />
                
                <Button Text="View on GitHub"
                        Command="{Binding OpenGitHubCommand}"
                        BackgroundColor="#2D3748"
                        TextColor="White"
                        Padding="15"
                        CornerRadius="5"
                        FontSize="14" />

                <Label Text="https://github.com/aungkokomm/English-Myanmar-Dictionary-"
                       FontSize="11"
                       HorizontalTextAlignment="Center"
                       TextColor="{StaticResource LightTextColor}" />
            </VerticalStackLayout>

            <!-- Copyright -->
            <Label Text="© 2024 AKK Dictionary Team"
                   FontSize="12"
                   HorizontalTextAlignment="Center"
                   TextColor="{StaticResource LightTextColor}"
                   Margin="0,20,0,0" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
