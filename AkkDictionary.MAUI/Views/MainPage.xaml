<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AkkDictionary.MAUI.Views.MainPage"
             Title="Dictionary Search"
             BackgroundColor="{StaticResource PageBackgroundColor}">

    <VerticalStackLayout Spacing="10" Padding="10">
        <!-- Search Box -->
        <Entry x:Name="SearchBox"
               Placeholder="Search words..."
               FontSize="16"
               Padding="10"
               Text="{Binding SearchQuery}"
               PlaceholderColor="#999"
               TextColor="{StaticResource TextColor}" />

        <!-- Reverse Search Toggle -->
        <CheckBox x:Name="ReverseSearchToggle"
                  IsChecked="{Binding IsReverseSearch}"
                  Content="Search in definitions (Myanmar→English)"
                  VerticalOptions="Start" />

        <!-- Clear Button -->
        <Button Text="Clear Search"
                Command="{Binding ClearCommand}"
                BackgroundColor="{StaticResource SecondaryColor}"
                TextColor="White"
                Padding="10"
                CornerRadius="5" />

        <!-- Results List -->
        <Label Text="Dictionary Results:" 
               FontSize="14" 
               FontAttributes="Bold"
               Margin="0,10,0,5"
               TextColor="{StaticResource TextColor}" />

        <CollectionView ItemsSource="{Binding Results}" 
                        SelectionMode="Single"
                        SelectionChangedCommand="{Binding SelectResultCommand}"
                        SelectionChangedCommandParameter="{Binding .}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="5" 
                           Padding="10" 
                           BorderColor="#E0E0E0"
                           HasShadow="False">
                        <StackLayout Spacing="5">
                            <Label Text="{Binding DisplayHeadword}" 
                                   FontSize="16" 
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource PrimaryColor}" />
                            <Label Text="{Binding Pos}" 
                                   FontSize="12" 
                                   TextColor="{StaticResource LightTextColor}" />
                            <Label Text="{Binding Senses, StringFormat='Definitions: {0}'}" 
                                   FontSize="12" 
                                   TextColor="{StaticResource LightTextColor}" />
                        </StackPanel>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Definition Display -->
        <Label Text="Definition:" 
               FontSize="14" 
               FontAttributes="Bold"
               Margin="0,10,0,5"
               TextColor="{StaticResource TextColor}"
               IsVisible="{Binding SelectedDefinition, Converter={StaticResource StringNullToBoolConverter}}" />

        <ScrollView IsVisible="{Binding SelectedDefinition, Converter={StaticResource StringNullToBoolConverter}}">
            <Label Text="{Binding SelectedDefinition}" 
                   FontSize="13"
                   TextWrapping="WordWrap"
                   Padding="5"
                   TextColor="{StaticResource TextColor}" />
        </ScrollView>
    </VerticalStackLayout>

</ContentPage>
